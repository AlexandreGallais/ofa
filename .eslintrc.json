{
    "env": {
        "browser": true,
        "es2021": true
    },
    "extends": [
        "eslint:recommended",
        "plugin:@typescript-eslint/recommended",
        "plugin:vue/vue3-essential",
        "plugin:prettier/recommended"
    ],
    "parserOptions": {
        "ecmaVersion": "latest",
        "parser": "@typescript-eslint/parser",
        "sourceType": "module"
    },
    "plugins": ["@typescript-eslint", "vue"],
    "rules": {
        "prettier/prettier": [2, { "singleQuote": true }],

        "no-promise-executor-return": [2],
        "no-use-before-define": [2],
        "block-scoped-var": [2],
        "consistent-return": [2],
        "default-case": [2],
        "eqeqeq": [2],
        "grouped-accessor-pairs": [2, "getBeforeSet"],
        "no-console": [1],
        "no-else-return": [2],
        "no-magic-numbers": [1],
        "no-plusplus": [2],
        "no-shadow": [2],
        "no-var": [2],
        "prefer-const": [1],
        "prefer-destructuring": [2],
        "prefer-template": [2],
        "require-await": [2],
        "vars-on-top": [2],
        "yoda": [2]
    }
}

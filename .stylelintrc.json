{
    "extends": [
        "stylelint-config-standard-scss",
        "stylelint-config-recommended-vue"
    ],

    "plugins": ["stylelint-order"],

    "rules": {
        "order/order": [
            "custom-properties",
            "dollar-variables",
            "at-variables",
            "declarations",
            "rules",
            "at-rules",
            "less-mixins"
        ],

        "order/properties-order": [
            [
                "all",

                "display",
                "box-sizing",

                "margin",
                "padding",

                "color",

                "background-color",

                "border",
                "border-color",
                "border-radius",
                "outline",

                "font-family",
                "font-size",
                "font-weight",
                "line-height",

                "cursor"
            ],
            {
                "severity": "warning"
            }
        ]
    }
}
